<UserControl x:Class="XivLinker.App.Views.AutoCraftSequenceListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="{StaticResource App.GridLength.ContentGap}" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="&#x81EA;&#x52D5;&#x30AF;&#x30E9;&#x30D5;&#x30C8;"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Margin="0,2,0,0"
                           Text="&#x767B;&#x9332;&#x6E08;&#x307F;&#x30B7;&#x30FC;&#x30B1;&#x30F3;&#x30B9;&#x3092;&#x3059;&#x3070;&#x3084;&#x304F;&#x78BA;&#x8A8D;&#x3067;&#x304D;&#x307E;&#x3059;&#x3002;"
                           Style="{StaticResource CaptionTextStyle}"
                           Foreground="{DynamicResource App.Brush.TextSecondary}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Button Grid.Column="1"
                    VerticalAlignment="Center"
                    Command="{Binding CreateSequenceCommand}"
                    Style="{StaticResource SmallActionButtonStyle}">
                <TextBlock Text="&#x65B0;&#x898F;&#x4F5C;&#x6210;" />
            </Button>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource DenseSubtlePanelStyle}">
            <Grid>
                <Border Padding="{StaticResource App.Thickness.PanelPaddingDense}"
                        Background="{DynamicResource App.Brush.Surface}"
                        BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource App.CornerRadius.Control}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Sequences.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="{Binding EmptyMessage}"
                                   Style="{StaticResource BodyTextStyle}" />
                        <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                                   Text="&#x307E;&#x305A;&#x306F;&#x65B0;&#x3057;&#x3044;&#x30B7;&#x30FC;&#x30B1;&#x30F3;&#x30B9;&#x3092;&#x4F5C;&#x6210;&#x3057;&#x3066;&#x304F;&#x3060;&#x3055;&#x3044;&#x3002;"
                                   Style="{StaticResource CaptionTextStyle}" />
                        <Button Margin="{StaticResource App.Thickness.TopGapS}"
                                HorizontalAlignment="Left"
                                Command="{Binding CreateSequenceCommand}"
                                Style="{StaticResource SmallActionButtonStyle}">
                            <TextBlock Text="&#x65B0;&#x898F;&#x4F5C;&#x6210;" />
                        </Button>
                    </StackPanel>
                </Border>

                <ListBox ItemsSource="{Binding Sequences}"
                         ItemContainerStyle="{StaticResource FlatListBoxItemStyle}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Style>
                        <Style TargetType="ListBox">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Sequences.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,6"
                                    Padding="{StaticResource App.Thickness.ListItemDensePadding}"
                                    CornerRadius="{StaticResource App.CornerRadius.Control}"
                                    Background="{DynamicResource App.Brush.Surface}"
                                    BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource CardTitleTextStyle}" />
                                        <TextBlock Margin="0,2,0,0"
                                                   Text="{Binding Summary}"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Foreground="{DynamicResource App.Brush.TextSecondary}"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <TextBlock Margin="0,0,12,0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding UpdatedAtText}"
                                                   Style="{StaticResource CaptionTextStyle}" />

                                        <Button Command="{Binding DataContext.EditSequenceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource TinyActionButtonStyle}">
                                            <TextBlock Text="&#x7DE8;&#x96C6;" />
                                        </Button>

                                        <Button Margin="6,0,0,0"
                                                Command="{Binding DataContext.DeleteSequenceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource TinyDangerActionButtonStyle}">
                                            <TextBlock Text="&#x524A;&#x9664;" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
