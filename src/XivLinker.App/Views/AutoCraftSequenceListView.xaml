<UserControl x:Class="XivLinker.App.Views.AutoCraftSequenceListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="{StaticResource App.GridLength.SectionGap}" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SectionSurfaceStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="クラフトシーケンス一覧"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                               Text="登録済みシーケンスを確認し、新規作成や編集をすばやく行えます。"
                               Style="{StaticResource BodyTextStyle}"
                               Foreground="{DynamicResource App.Brush.TextSecondary}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Button Grid.Column="1"
                        VerticalAlignment="Top"
                        Command="{Binding CreateSequenceCommand}"
                        Style="{StaticResource ActionButtonStyle}">
                    <TextBlock Text="新規作成" />
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource SubtlePanelStyle}">
            <Grid>
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="{Binding EmptyMessage}"
                           Foreground="{DynamicResource App.Brush.TextMuted}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Sequences.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ListBox ItemsSource="{Binding Sequences}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Style>
                        <Style TargetType="ListBox">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Sequences.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="{StaticResource App.Thickness.ListItemPadding}"
                                    CornerRadius="{StaticResource App.CornerRadius.Control}"
                                    Background="{DynamicResource App.Brush.Surface}"
                                    BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="{StaticResource App.GridLength.ContentGap}" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="{StaticResource App.GridLength.ContentGap}" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource CardTitleTextStyle}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding Summary}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   Foreground="{DynamicResource App.Brush.TextSecondary}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="3"
                                               VerticalAlignment="Top"
                                               Text="{Binding UpdatedAtText}"
                                               Style="{StaticResource CaptionTextStyle}" />

                                    <Button Grid.Row="2"
                                            Grid.Column="1"
                                            Command="{Binding DataContext.EditSequenceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SmallActionButtonStyle}">
                                        <TextBlock Text="編集" />
                                    </Button>

                                    <Button Grid.Row="2"
                                            Grid.Column="3"
                                            Command="{Binding DataContext.DeleteSequenceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource DangerActionButtonStyle}">
                                        <TextBlock Text="削除" />
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
