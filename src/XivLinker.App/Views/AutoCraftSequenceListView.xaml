<UserControl x:Class="XivLinker.App.Views.AutoCraftSequenceListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:XivLinker.App.Views">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="{StaticResource App.GridLength.PageContentSpacing}" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <views:PageHeaderView Title="&#x81EA;&#x52D5;&#x30AF;&#x30E9;&#x30D5;&#x30C8;"
                              Description="&#x767B;&#x9332;&#x6E08;&#x307F;&#x30B7;&#x30FC;&#x30B1;&#x30F3;&#x30B9;&#x3092;&#x3059;&#x3070;&#x3084;&#x304F;&#x78BA;&#x8A8D;&#x3067;&#x304D;&#x307E;&#x3059;&#x3002;">
            <views:PageHeaderView.ActionContent>
                <Button Command="{Binding CreateSequenceCommand}"
                        Style="{StaticResource SmallActionButtonStyle}">
                    <TextBlock Text="&#x65B0;&#x898F;&#x4F5C;&#x6210;" />
                </Button>
            </views:PageHeaderView.ActionContent>
        </views:PageHeaderView>

        <Border Grid.Row="2"
                Style="{StaticResource DenseSubtlePanelStyle}">
            <Grid>
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Sequences.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{Binding EmptyMessage}"
                               HorizontalAlignment="Center"
                               Style="{StaticResource BodyTextStyle}" />
                    <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                               Text="&#x53F3;&#x4E0A;&#x306E;&#x65B0;&#x898F;&#x4F5C;&#x6210;&#x304B;&#x3089;&#x30B7;&#x30FC;&#x30B1;&#x30F3;&#x30B9;&#x3092;&#x8FFD;&#x52A0;&#x3067;&#x304D;&#x307E;&#x3059;&#x3002;"
                               HorizontalAlignment="Center"
                               Style="{StaticResource CaptionTextStyle}" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Sequences}"
                         ItemContainerStyle="{StaticResource FlatListBoxItemStyle}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Style>
                        <Style TargetType="ListBox">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Sequences.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,6"
                                    Padding="{StaticResource App.Thickness.ListItemDensePadding}"
                                    CornerRadius="{StaticResource App.CornerRadius.Control}"
                                    Background="{DynamicResource App.Brush.Surface}"
                                    BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource CardTitleTextStyle}" />
                                        <TextBlock Margin="0,2,0,0"
                                                   Text="{Binding Summary}"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Foreground="{DynamicResource App.Brush.TextSecondary}"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <TextBlock Margin="0,0,12,0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding UpdatedAtText}"
                                                   Style="{StaticResource CaptionTextStyle}" />

                                        <Button Command="{Binding DataContext.EditSequenceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource TinyActionButtonStyle}">
                                            <TextBlock Text="&#x7DE8;&#x96C6;" />
                                        </Button>

                                        <Button Margin="6,0,0,0"
                                                Command="{Binding DataContext.DeleteSequenceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource TinyDangerActionButtonStyle}">
                                            <TextBlock Text="&#x524A;&#x9664;" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
