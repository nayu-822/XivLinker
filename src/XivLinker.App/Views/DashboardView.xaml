<UserControl x:Class="XivLinker.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:XivLinker.App.Views">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="{StaticResource App.GridLength.PageContentSpacing}" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="{StaticResource App.GridLength.SectionGap}" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <views:PageHeaderView Title="&#x30C0;&#x30C3;&#x30B7;&#x30E5;&#x30DC;&#x30FC;&#x30C9;"
                              Description="&#x73FE;&#x5728;&#x306E;&#x72B6;&#x614B;&#x3068;&#x63A5;&#x7D9A;&#x30FB;&#x9023;&#x643A;&#x72B6;&#x614B;&#x3092;&#x78BA;&#x8A8D;&#x3067;&#x304D;&#x307E;&#x3059;&#x3002;" />

        <ItemsControl Grid.Row="2"
                      ItemsSource="{Binding DataSourceStatus.Items}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,8,0"
                            Style="{StaticResource DashboardStatusCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="{StaticResource App.GridLength.GapS}" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Name}"
                                       Style="{StaticResource LabelTextStyle}" />
                            <TextBlock Grid.Row="2"
                                       Text="{Binding Status}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CardTitleTextStyle}">
                                        <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusTone}" Value="success">
                                                <Setter Property="Foreground" Value="{DynamicResource App.Brush.Success}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusTone}" Value="warning">
                                                <Setter Property="Foreground" Value="{DynamicResource App.Brush.Warning}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusTone}" Value="error">
                                                <Setter Property="Foreground" Value="{DynamicResource App.Brush.Error}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="{StaticResource App.GridLength.SectionGap}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CompactCardStyle}">
                <StackPanel>
                    <TextBlock Text="&#x73FE;&#x5728;&#x306E;&#x72B6;&#x614B;"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <Grid Margin="{StaticResource App.Thickness.TopGapM}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="&#x73FE;&#x5728;&#x30DE;&#x30C3;&#x30D7;"
                                   Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Status.CurrentMap}"
                                   Style="{StaticResource ValueTextStyle}" />

                        <TextBlock Grid.Row="1"
                                   Margin="{StaticResource App.Thickness.TopGapM}"
                                   Text="&#x73FE;&#x5728;&#x5EA7;&#x6A19;"
                                   Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="{StaticResource App.Thickness.TopGapM}"
                                   Text="{Binding Status.CurrentCoordinates}"
                                   Style="{StaticResource ValueTextStyle}" />

                        <TextBlock Grid.Row="2"
                                   Margin="{StaticResource App.Thickness.TopGapM}"
                                   Text="&#x73FE;&#x5728;&#x30B8;&#x30E7;&#x30D6;"
                                   Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="{StaticResource App.Thickness.TopGapM}"
                                   Text="{Binding Status.CurrentJob}"
                                   Style="{StaticResource ValueTextStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CompactCardStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#x30C7;&#x30FC;&#x30BF;&#x53D6;&#x5F97;&#x57FA;&#x76E4;"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <Button Grid.Column="1"
                                Command="{Binding DataContext.NavigateToKeyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="settings"
                                Style="{StaticResource SmallActionButtonStyle}">
                            <TextBlock Text="&#x8A2D;&#x5B9A;&#x3092;&#x958B;&#x304F;" />
                        </Button>
                    </Grid>
                    <ItemsControl Margin="{StaticResource App.Thickness.TopGapM}"
                                  ItemsSource="{Binding DataSourceStatus.Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Style="{StaticResource DenseSubtlePanelStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource CardTitleTextStyle}" />

                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Status}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource InlineStatusTextStyle}">
                                                    <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextSecondary}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusTone}" Value="success">
                                                            <Setter Property="Foreground" Value="{DynamicResource App.Brush.Success}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusTone}" Value="warning">
                                                            <Setter Property="Foreground" Value="{DynamicResource App.Brush.Warning}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusTone}" Value="error">
                                                            <Setter Property="Foreground" Value="{DynamicResource App.Brush.Error}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Grid.Row="1"
                                                   Margin="{StaticResource App.Thickness.TopGapS}"
                                                   Text="{Binding SupplementText}"
                                                   Foreground="{DynamicResource App.Brush.TextSecondary}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasSupplementText}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Button Grid.Row="1"
                                                Grid.ColumnSpan="2"
                                                Margin="{StaticResource App.Thickness.TopGapM}"
                                                HorizontalAlignment="Left"
                                                Command="{Binding ActionCommand}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SmallActionButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAction}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding HasSupplementText}" Value="True">
                                                            <Setter Property="Margin" Value="0,10,0,0" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="{Binding ActionLabel}" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
