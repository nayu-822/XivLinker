<UserControl x:Class="XivLinker.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroPanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="XivLinker"
                               Style="{StaticResource AppTitleTextStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="OverlayPlugin、Lumina、キャラクター設定、ログ連携の状態を集約するダッシュボードです。"
                               Style="{StaticResource BodyTextStyle}"
                               Foreground="{DynamicResource App.Brush.TextSecondary}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1"
                        Style="{StaticResource StatusSummaryPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="接続状態"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <ItemsControl Margin="0,16,0,0"
                                      ItemsSource="{Binding Shell.DataSources}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource LabelTextStyle}" />
                                        <Border Grid.Column="1"
                                                Style="{StaticResource StatusPillStyle}">
                                            <TextBlock Text="{Binding Status}"
                                                       Style="{StaticResource StatusPillTextStyle}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="現在の状態"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <Grid Margin="0,18,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="エリア"
                                   Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Shell.CurrentArea}"
                                   Style="{StaticResource ValueTextStyle}" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,12,0,0"
                                   Text="キャラクター"
                                   Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Text="{Binding Shell.CurrentCharacter}"
                                   Style="{StaticResource ValueTextStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="データ取得基盤"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <ItemsControl Margin="0,18,0,0"
                                  ItemsSource="{Binding Shell.DataSources}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,12"
                                        Padding="14"
                                        CornerRadius="{StaticResource App.CornerRadius.Control}"
                                        Background="{DynamicResource App.Brush.SurfaceAlt}"
                                        BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       Style="{StaticResource CardTitleTextStyle}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding Detail}"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Status}"
                                                   Style="{StaticResource InlineStatusTextStyle}" />

                                        <Button Grid.Row="1"
                                                Grid.ColumnSpan="2"
                                                Margin="0,12,0,0"
                                                HorizontalAlignment="Left"
                                                Command="{Binding ActionCommand}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAction}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="{Binding ActionLabel}" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="イベントログ"
                           Style="{StaticResource SectionTitleTextStyle}" />

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Shell.EventLogs}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Padding="14"
                                    CornerRadius="{StaticResource App.CornerRadius.Control}"
                                    Background="{DynamicResource App.Brush.SurfaceAlt}"
                                    BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding}"
                                           Style="{StaticResource LogTextStyle}"
                                           TextWrapping="Wrap" />
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
