<UserControl x:Class="XivLinker.App.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:XivLinker.App.Views">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="{StaticResource App.GridLength.PageContentSpacing}" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <views:PageHeaderView Title="&#x30ED;&#x30B0;"
                              Description="&#x30A4;&#x30D9;&#x30F3;&#x30C8;&#x30ED;&#x30B0;&#x3084;&#x63A5;&#x7D9A;&#x72B6;&#x614B;&#x306E;&#x5909;&#x5316;&#x3092;&#x78BA;&#x8A8D;&#x3067;&#x304D;&#x307E;&#x3059;&#x3002;">
            <views:PageHeaderView.ActionContent>
                <Button Command="{Binding ClearLogCommand}"
                        Style="{StaticResource SmallActionButtonStyle}">
                    <TextBlock Text="&#x30ED;&#x30B0;&#x3092;&#x30AF;&#x30EA;&#x30A2;" />
                </Button>
            </views:PageHeaderView.ActionContent>
        </views:PageHeaderView>

        <Border Grid.Row="2"
                Style="{StaticResource CompactCardStyle}">
            <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                        Background="Transparent"
                        BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabControl">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabControl">
                                    <Grid KeyboardNavigation.TabNavigation="Local">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                HorizontalAlignment="Left"
                                                Padding="2"
                                                Background="{DynamicResource App.Brush.SurfaceAlt}"
                                                BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource App.CornerRadius.Control}">
                                            <TabPanel Margin="0"
                                                      Background="Transparent"
                                                      IsItemsHost="True"
                                                      Panel.ZIndex="1" />
                                        </Border>

                                        <ContentPresenter Grid.Row="1"
                                                          ContentSource="SelectedContent"
                                                          Margin="0,16,0,0" />
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style TargetType="TabItem">
                        <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextSecondary}" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Padding" Value="12,7" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabBorder"
                                            Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="{StaticResource App.CornerRadius.Control}">
                                        <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          RecognizesAccessKey="True" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource App.Brush.Accent}" />
                                            <Setter Property="Foreground" Value="{DynamicResource App.Brush.OnAccent}" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource App.Brush.NavigationHover}" />
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsSelected" Value="True" />
                                                <Condition Property="IsMouseOver" Value="True" />
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource App.Brush.Accent}" />
                                            <Setter Property="Foreground" Value="{DynamicResource App.Brush.OnAccent}" />
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="&#x30A2;&#x30D7;&#x30EA;&#x30ED;&#x30B0;">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="{StaticResource App.GridLength.ContentGap}" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="88" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#x6642;&#x523B;"
                                       Style="{StaticResource LabelTextStyle}" />
                            <TextBlock Grid.Column="1"
                                       Text="&#x7A2E;&#x5225;"
                                       Style="{StaticResource LabelTextStyle}" />
                            <TextBlock Grid.Column="2"
                                       Text="&#x30E1;&#x30C3;&#x30BB;&#x30FC;&#x30B8;"
                                       Style="{StaticResource LabelTextStyle}" />
                        </Grid>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding EventLog.Items}"
                                 ItemContainerStyle="{StaticResource FlatListBoxItemStyle}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6"
                                            Style="{StaticResource LogRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    CornerRadius="2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource App.Brush.Accent}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                <Setter Property="Background" Value="{DynamicResource App.Brush.Warning}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                <Setter Property="Background" Value="{DynamicResource App.Brush.Error}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>

                                            <TextBlock Grid.Column="1"
                                                       VerticalAlignment="Top"
                                                       Text="{Binding TimestampText}"
                                                       Style="{StaticResource CaptionTextStyle}" />
                                            <TextBlock Grid.Column="3"
                                                       VerticalAlignment="Top"
                                                       Text="{Binding Level}"
                                                       Style="{StaticResource CaptionTextStyle}" />
                                            <TextBlock Grid.Column="5"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Message}"
                                                       Style="{StaticResource LogTextStyle}"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Message}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>

                <TabItem Header="WebSocket&#x901A;&#x4FE1;">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="{StaticResource App.GridLength.ContentGap}" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="84" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#x6642;&#x523B;" Style="{StaticResource LabelTextStyle}" />
                            <TextBlock Grid.Column="1" Text="&#x65B9;&#x5411;" Style="{StaticResource LabelTextStyle}" />
                            <TextBlock Grid.Column="2" Text="raw JSON" Style="{StaticResource LabelTextStyle}" />
                        </Grid>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding WebSocketLog.Items}"
                                 ItemContainerStyle="{StaticResource FlatListBoxItemStyle}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6"
                                            Style="{StaticResource LogRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="96" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       VerticalAlignment="Top"
                                                       Text="{Binding TimestampText}"
                                                       Style="{StaticResource CaptionTextStyle}" />
                                            <TextBlock Grid.Column="2"
                                                       VerticalAlignment="Top"
                                                       Text="{Binding Direction}"
                                                       Style="{StaticResource CaptionTextStyle}" />
                                            <TextBlock Grid.Column="4"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding RawJson}"
                                                       Style="{StaticResource LogTextStyle}"
                                                       TextWrapping="Wrap"
                                                       ToolTip="{Binding RawJson}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
