<UserControl x:Class="XivLinker.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:XivLinker.App.Views">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="{StaticResource App.GridLength.PageContentSpacing}" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <views:PageHeaderView Title="&#x8A2D;&#x5B9A;"
                              Description="&#x63A5;&#x7D9A;&#x8A2D;&#x5B9A;&#x3084;&#x53C2;&#x7167;&#x30D1;&#x30B9;&#x3001;&#x30A2;&#x30D7;&#x30EA;&#x306E;&#x52D5;&#x4F5C;&#x8A2D;&#x5B9A;&#x3092;&#x7BA1;&#x7406;&#x3057;&#x307E;&#x3059;&#x3002;" />

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="0,0,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="{StaticResource App.GridLength.SectionGap}" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="{StaticResource App.GridLength.SectionGap}" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="{StaticResource App.GridLength.SectionGap}" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="{StaticResource App.GridLength.SectionGap}" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CompactCardStyle}">
                    <StackPanel>
                        <TextBlock Text="&#x63A5;&#x7D9A;&#x8A2D;&#x5B9A;"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="{StaticResource App.Thickness.TopGapM}"
                                   Text="OverlayPlugin WebSocket"
                                   Style="{StaticResource LabelTextStyle}" />
                        <Border Margin="{StaticResource App.Thickness.TopGapS}"
                                Style="{StaticResource ReadOnlyValueContainerStyle}">
                            <TextBlock Text="{Binding OverlayWebSocketUri, Mode=OneWay}"
                                       Style="{StaticResource BodyTextStyle}"
                                       TextWrapping="Wrap" />
                        </Border>
                        <Button Margin="{StaticResource App.Thickness.TopGapM}"
                                HorizontalAlignment="Left"
                                Command="{Binding ReconnectOverlayCommand}"
                                Style="{StaticResource SmallActionButtonStyle}">
                            <TextBlock Text="&#x518D;&#x63A5;&#x7D9A;" />
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource CompactCardStyle}">
                    <StackPanel>
                        <TextBlock Text="FF14 / Lumina &#x8A2D;&#x5B9A;"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="{StaticResource App.Thickness.TopGapM}"
                                   Text="sqpack &#x30D1;&#x30B9;"
                                   Style="{StaticResource LabelTextStyle}" />
                        <Border Margin="{StaticResource App.Thickness.TopGapS}"
                                Style="{StaticResource ReadOnlyValueContainerStyle}">
                            <TextBlock Text="{Binding SqPackPath, Mode=OneWay}"
                                       Style="{StaticResource BodyTextStyle}"
                                       TextWrapping="Wrap" />
                        </Border>
                        <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                                   Text="{Binding LuminaPathDescription}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Foreground="{DynamicResource App.Brush.TextSecondary}"
                                   TextWrapping="Wrap" />
                        <StackPanel Margin="{StaticResource App.Thickness.TopGapM}"
                                    Orientation="Horizontal">
                            <Button Command="{Binding RefreshLuminaCommand}"
                                    Style="{StaticResource SmallActionButtonStyle}">
                                <TextBlock Text="&#x72B6;&#x614B;&#x3092;&#x78BA;&#x8A8D;" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4"
                        Style="{StaticResource CompactCardStyle}">
                    <StackPanel>
                        <TextBlock Text="&#x30AD;&#x30E3;&#x30E9;&#x30AF;&#x30BF;&#x30FC;&#x8A2D;&#x5B9A;"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="{StaticResource App.Thickness.TopGapM}"
                                   Text="{Binding CharacterConfigStatus}"
                                   Style="{StaticResource BodyTextStyle}" />
                        <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                                   Text="{Binding CharacterConfigDescription}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Foreground="{DynamicResource App.Brush.TextSecondary}"
                                   TextWrapping="Wrap" />
                        <Button Margin="{StaticResource App.Thickness.TopGapM}"
                                HorizontalAlignment="Left"
                                Command="{Binding AddCharacterProfileCommand}"
                                Style="{StaticResource SmallActionButtonStyle}">
                            <TextBlock Text="&#x30AD;&#x30E3;&#x30E9;&#x30AF;&#x30BF;&#x30FC;&#x8A2D;&#x5B9A;&#x30D5;&#x30A9;&#x30EB;&#x30C0;&#x30FC;&#x3092;&#x8FFD;&#x52A0;" />
                        </Button>

                        <Border Margin="{StaticResource App.Thickness.TopGapM}"
                                Style="{StaticResource DenseSubtlePanelStyle}">
                            <Grid>
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CharacterProfiles.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="&#x307E;&#x3060;&#x30AD;&#x30E3;&#x30E9;&#x30AF;&#x30BF;&#x30FC;&#x8A2D;&#x5B9A;&#x304C;&#x767B;&#x9332;&#x3055;&#x308C;&#x3066;&#x3044;&#x307E;&#x305B;&#x3093;&#x3002;"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                                               Text="FF14 &#x306E; CHR... &#x30D5;&#x30A9;&#x30EB;&#x30C0;&#x30FC;&#x3092;&#x9078;&#x3093;&#x3067;&#x8FFD;&#x52A0;&#x3057;&#x3066;&#x304F;&#x3060;&#x3055;&#x3044;&#x3002;"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Foreground="{DynamicResource App.Brush.TextSecondary}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding CharacterProfiles}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CharacterProfiles.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="{StaticResource App.Thickness.ListItemDensePadding}"
                                                    Background="{DynamicResource App.Brush.Surface}"
                                                    BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource App.CornerRadius.Control}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Style="{StaticResource CardTitleTextStyle}" />
                                                        <Border Margin="8,0,0,0"
                                                                Padding="8,2"
                                                                Background="{DynamicResource App.Brush.SurfaceStrong}"
                                                                BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                                                                BorderThickness="1"
                                                                CornerRadius="{StaticResource App.CornerRadius.Pill}">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="&#x9078;&#x629E;&#x4E2D;"
                                                                       Style="{StaticResource CaptionTextStyle}" />
                                                        </Border>
                                                    </StackPanel>

                                                    <TextBlock Grid.Row="1"
                                                               Grid.ColumnSpan="2"
                                                               Margin="{StaticResource App.Thickness.TopGapS}"
                                                               Text="{Binding CharacterSettingsDirectory}"
                                                               Style="{StaticResource CaptionTextStyle}"
                                                               Foreground="{DynamicResource App.Brush.TextSecondary}"
                                                               TextWrapping="Wrap" />

                                                    <Grid Grid.Row="2"
                                                          Grid.ColumnSpan="2"
                                                          Margin="{StaticResource App.Thickness.TopGapM}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="{StaticResource App.GridLength.GapS}" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="{StaticResource App.GridLength.GapS}" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock VerticalAlignment="Center"
                                                                   Text="{Binding LastLoadedAtText}"
                                                                   Style="{StaticResource CaptionTextStyle}"
                                                                   Foreground="{DynamicResource App.Brush.TextSecondary}" />

                                                        <Button Grid.Column="1"
                                                                Command="{Binding DataContext.SelectCharacterProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SmallActionButtonStyle}">
                                                            <TextBlock Text="&#x9078;&#x629E;" />
                                                        </Button>

                                                        <Button Grid.Column="3"
                                                                Command="{Binding DataContext.ReloadCharacterProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SmallActionButtonStyle}">
                                                            <TextBlock Text="&#x518D;&#x8AAD;&#x307F;&#x8FBC;&#x307F;" />
                                                        </Button>

                                                        <Button Grid.Column="5"
                                                                Command="{Binding DataContext.RemoveCharacterProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource TinyDangerActionButtonStyle}">
                                                            <TextBlock Text="&#x524A;&#x9664;" />
                                                        </Button>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <Border Margin="{StaticResource App.Thickness.TopGapM}"
                                Style="{StaticResource DenseSubtlePanelStyle}">
                            <StackPanel>
                                <TextBlock Text="&#x9078;&#x629E;&#x4E2D;&#x30AD;&#x30E3;&#x30E9;&#x30AF;&#x30BF;&#x30FC;"
                                           Style="{StaticResource LabelTextStyle}" />
                                <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                                           Text="{Binding SelectedCharacterName}"
                                           Style="{StaticResource CardTitleTextStyle}" />
                                <TextBlock Margin="{StaticResource App.Thickness.TopGapM}"
                                           Text="表示名"
                                           Style="{StaticResource LabelTextStyle}" />
                                <Grid Margin="{StaticResource App.Thickness.TopGapM}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding EditableSelectedCharacterName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputTextBoxStyle}" />
                                    <Button Grid.Column="1"
                                            Margin="{StaticResource App.Thickness.PageHeaderActionSpacing}"
                                            Command="{Binding SaveSelectedCharacterNameCommand}"
                                            Style="{StaticResource SmallActionButtonStyle}">
                                        <TextBlock Text="&#x540D;&#x524D;&#x3092;&#x4FDD;&#x5B58;" />
                                    </Button>
                                </Grid>
                                <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                                           Text="{Binding CharacterNameDescription}"
                                           Style="{StaticResource CaptionTextStyle}"
                                           Foreground="{DynamicResource App.Brush.TextSecondary}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="{StaticResource App.Thickness.TopGapM}"
                                           Text="{Binding SelectedCharacterStatus}"
                                           Style="{StaticResource BodyTextStyle}" />
                                <Grid Margin="{StaticResource App.Thickness.TopGapM}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="HOTBAR.DAT"
                                               Style="{StaticResource LabelTextStyle}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SelectedHotbarStatus}"
                                               Style="{StaticResource BodyTextStyle}" />

                                    <TextBlock Grid.Row="1"
                                               Margin="{StaticResource App.Thickness.TopGapS}"
                                               Text="KEYBIND.DAT"
                                               Style="{StaticResource LabelTextStyle}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Margin="{StaticResource App.Thickness.TopGapS}"
                                               Text="{Binding SelectedKeybindStatus}"
                                               Style="{StaticResource BodyTextStyle}" />
                                </Grid>
                                <Border Margin="{StaticResource App.Thickness.TopGapM}"
                                        Style="{StaticResource ReadOnlyValueContainerStyle}">
                                    <StackPanel>
                                        <TextBlock Text="HOTBAR.DAT"
                                                   Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                                                   Text="{Binding SelectedHotbarPath}"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="{StaticResource App.Thickness.TopGapM}"
                                                   Text="KEYBIND.DAT"
                                                   Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                                                   Text="{Binding SelectedKeybindPath}"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Margin="{StaticResource App.Thickness.TopGapM}"
                                           Text="{Binding SelectedCharacterErrors}"
                                           Foreground="{DynamicResource App.Brush.Error}"
                                           TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCharacterErrors}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedCharacterErrors}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="6"
                        Style="{StaticResource CompactCardStyle}">
                    <StackPanel>
                        <TextBlock Text="アプリデータ管理"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="{StaticResource App.Thickness.TopGapM}"
                                   Text="アプリが利用しているキャッシュとログファイルを確認し、必要に応じて整理できます。"
                                   Style="{StaticResource BodyTextStyle}"
                                   TextWrapping="Wrap" />

                        <Border Margin="{StaticResource App.Thickness.TopGapM}"
                                Style="{StaticResource ReadOnlyValueContainerStyle}">
                            <TextBlock Text="{Binding AppDataRootPath}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <StackPanel Margin="{StaticResource App.Thickness.TopGapM}"
                                    Orientation="Horizontal">
                            <Button Command="{Binding OpenAppDataFolderCommand}"
                                    Style="{StaticResource SmallActionButtonStyle}">
                                <TextBlock Text="アプリデータフォルダーを開く" />
                            </Button>

                            <Button Margin="{StaticResource App.Thickness.PageHeaderActionSpacing}"
                                    Command="{Binding RefreshAppDataStatsCommand}"
                                    Style="{StaticResource SmallActionButtonStyle}">
                                <TextBlock Text="再読み込み" />
                            </Button>
                        </StackPanel>

                        <Border Margin="{StaticResource App.Thickness.TopGapM}"
                                Style="{StaticResource DenseSubtlePanelStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="{StaticResource App.GridLength.GapS}" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="アイコンキャッシュ"
                                               Style="{StaticResource LabelTextStyle}" />
                                    <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                                               Text="{Binding IconCacheSummary}"
                                               Style="{StaticResource CaptionTextStyle}" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Command="{Binding OpenIconCacheFolderCommand}"
                                        Style="{StaticResource SmallActionButtonStyle}">
                                    <TextBlock Text="開く" />
                                </Button>

                                <Button Grid.Column="3"
                                        Command="{Binding ClearIconCacheCommand}"
                                        Style="{StaticResource TinyDangerActionButtonStyle}">
                                    <TextBlock Text="削除" />
                                </Button>
                            </Grid>
                        </Border>

                        <Border Margin="{StaticResource App.Thickness.TopGapM}"
                                Style="{StaticResource DenseSubtlePanelStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="{StaticResource App.GridLength.GapS}" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="ログファイル"
                                               Style="{StaticResource LabelTextStyle}" />
                                    <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                                               Text="{Binding LogFilesSummary}"
                                               Style="{StaticResource CaptionTextStyle}" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Command="{Binding OpenLogFolderCommand}"
                                        Style="{StaticResource SmallActionButtonStyle}">
                                    <TextBlock Text="開く" />
                                </Button>

                                <Button Grid.Column="3"
                                        Command="{Binding ClearLogFilesCommand}"
                                        Style="{StaticResource TinyDangerActionButtonStyle}">
                                    <TextBlock Text="削除" />
                                </Button>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="8"
                        Style="{StaticResource CompactCardStyle}">
                    <StackPanel>
                        <TextBlock Text="&#x30ED;&#x30B0;&#x8A2D;&#x5B9A;"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="{StaticResource App.Thickness.TopGapM}"
                                   Text="{Binding LogRetentionDescription}"
                                   Style="{StaticResource BodyTextStyle}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="{StaticResource App.Thickness.TopGapM}"
                                   Text="ファイルログ出力レベル"
                                   Style="{StaticResource LabelTextStyle}" />
                        <ComboBox Margin="{StaticResource App.Thickness.TopGapS}"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding FileLogLevelOptions}"
                                  SelectedItem="{Binding SelectedFileLogLevel}"
                                  Style="{StaticResource InputComboBoxStyle}" />
                        <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                                   Text="{Binding SelectedFileLogLevel.Description}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Foreground="{DynamicResource App.Brush.TextSecondary}"
                                   TextWrapping="Wrap" />
                        <Button Margin="{StaticResource App.Thickness.TopGapM}"
                                HorizontalAlignment="Left"
                                Command="{Binding ClearLogCommand}"
                                Style="{StaticResource SmallActionButtonStyle}">
                            <TextBlock Text="&#x30ED;&#x30B0;&#x3092;&#x30AF;&#x30EA;&#x30A2;" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
