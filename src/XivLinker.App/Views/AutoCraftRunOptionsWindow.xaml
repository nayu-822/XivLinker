<Window x:Class="XivLinker.App.Views.AutoCraftRunOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="自動クラフトを実行"
        Width="420"
        Height="280"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource WindowBaseStyle}">
    <Grid Margin="{StaticResource App.Thickness.PageDense}">
        <Border Style="{StaticResource CompactCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="{StaticResource App.GridLength.ContentGap}" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="{StaticResource App.GridLength.SectionGap}" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="自動クラフトを実行"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                               Text="{Binding SequenceName}"
                               Style="{StaticResource CardTitleTextStyle}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="クラフト回数"
                               Style="{StaticResource LabelTextStyle}" />
                    <TextBox Margin="{StaticResource App.Thickness.TopGapS}"
                             Text="{Binding RunCountText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBoxStyle}" />
                    <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                               Text="{Binding CountHelpText}"
                               Style="{StaticResource CaptionTextStyle}"
                               Foreground="{DynamicResource App.Brush.TextSecondary}" />
                    <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                               Text="{Binding ValidationMessage}"
                               Foreground="{DynamicResource App.Brush.Warning}"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasValidationMessage}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="{StaticResource App.GridLength.GapS}" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SmallActionButtonStyle}">
                        <TextBlock Text="キャンセル" />
                    </Button>

                    <Button Grid.Column="3"
                            Command="{Binding ConfirmCommand}"
                            Style="{StaticResource ActionButtonStyle}">
                        <TextBlock Text="実行" />
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
