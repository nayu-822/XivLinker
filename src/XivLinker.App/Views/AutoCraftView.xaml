<UserControl x:Class="XivLinker.App.Views.AutoCraftView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardStyle}">
        <StackPanel>
            <TextBlock Text="{Binding Title}"
                       Style="{StaticResource SectionTitleTextStyle}" />
            <TextBlock Margin="0,14,0,0"
                       Text="{Binding Description}"
                       Style="{StaticResource BodyTextStyle}"
                       Foreground="{DynamicResource App.Brush.TextSecondary}"
                       TextWrapping="Wrap" />
            <Border Margin="0,18,0,0"
                    Padding="14"
                    CornerRadius="{StaticResource App.CornerRadius.Control}"
                    Background="{DynamicResource App.Brush.SurfaceAlt}"
                    BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="状態"
                               Style="{StaticResource LabelTextStyle}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding Status}"
                               Style="{StaticResource ValueTextStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="Not implemented yet."
                               Style="{StaticResource CaptionTextStyle}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
