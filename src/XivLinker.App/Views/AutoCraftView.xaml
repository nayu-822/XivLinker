<UserControl x:Class="XivLinker.App.Views.AutoCraftView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:XivLinker.App.Views">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroPanelStyle}">
            <StackPanel>
                <TextBlock Text="{Binding Title}"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Margin="0,10,0,0"
                           Text="{Binding Description}"
                           Style="{StaticResource BodyTextStyle}"
                           Foreground="{DynamicResource App.Brush.TextSecondary}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <views:AutoCraftSequenceListView Grid.Row="2"
                                         DataContext="{Binding SequenceList}" />
    </Grid>
</UserControl>
