<UserControl x:Class="XivLinker.App.Views.AutoCraftView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:XivLinker.App.ViewModels"
             xmlns:views="clr-namespace:XivLinker.App.Views">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type viewModels:AutoCraftSequenceListViewModel}">
            <views:AutoCraftSequenceListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:AutoCraftSequenceEditorViewModel}">
            <views:AutoCraftSequenceEditorView />
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroPanelStyle}">
            <StackPanel>
                <TextBlock Text="{Binding Title}"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Margin="0,10,0,0"
                           Text="{Binding Description}"
                           Style="{StaticResource BodyTextStyle}"
                           Foreground="{DynamicResource App.Brush.TextSecondary}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <ContentControl Grid.Row="2"
                        Content="{Binding CurrentContentViewModel}" />
    </Grid>
</UserControl>
