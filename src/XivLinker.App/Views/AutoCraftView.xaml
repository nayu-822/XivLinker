<UserControl x:Class="XivLinker.App.Views.AutoCraftView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:XivLinker.App.Views">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="{StaticResource App.GridLength.PageContentSpacing}" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="{StaticResource App.GridLength.PageContentSpacing}" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <views:PageHeaderView Title="{Binding Title}"
                              Description="{Binding Description}">
            <views:PageHeaderView.ActionContent>
                <Button Command="{Binding SequenceList.CreateSequenceCommand}"
                        Style="{StaticResource SmallActionButtonStyle}">
                    <TextBlock Text="新規作成" />
                </Button>
            </views:PageHeaderView.ActionContent>
        </views:PageHeaderView>

        <Border Grid.Row="2"
                Padding="16,12"
                Background="{DynamicResource App.Brush.Surface}"
                BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                BorderThickness="1"
                CornerRadius="{StaticResource App.CornerRadius.Control}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Text="現在ジョブ"
                           Style="{StaticResource LabelTextStyle}" />

                <ComboBox Width="180"
                          VerticalAlignment="Center"
                          DisplayMemberPath="DisplayName"
                          TextSearch.TextPath="DisplayName"
                          IsEnabled="{Binding CanChangeCrafterJob}"
                          ItemsSource="{Binding DisplayedCrafterJobs}"
                          SelectedItem="{Binding SelectedCrafterJob}" />

                <TextBlock Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource App.Brush.TextSecondary}"
                           Text="{Binding CrafterJobStatusText}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <views:AutoCraftSequenceListView Grid.Row="4"
                                         DataContext="{Binding SequenceList}" />
    </Grid>
</UserControl>
