<UserControl x:Class="XivLinker.App.Views.AutoCraftSequenceEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="{StaticResource App.GridLength.SectionGap}" />
            <RowDefinition Height="*" />
            <RowDefinition Height="{StaticResource App.GridLength.ContentGap}" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding WindowTitle}"
                           VerticalAlignment="Center"
                           Style="{StaticResource SectionTitleTextStyle}" />

                <Border Grid.Column="1"
                        Margin="12,0,0,0"
                        Padding="10,4"
                        VerticalAlignment="Center"
                        Background="{DynamicResource App.Brush.SurfaceAlt}"
                        BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource App.CornerRadius.Pill}">
                    <TextBlock Text="{Binding Title}"
                               Style="{StaticResource CaptionTextStyle}" />
                </Border>
            </Grid>

            <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                       Text="手順の確認とアクション追加を行います。"
                       Style="{StaticResource BodyTextStyle}"
                       Foreground="{DynamicResource App.Brush.TextSecondary}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.02*" />
                <ColumnDefinition Width="{StaticResource App.GridLength.SectionGap}" />
                <ColumnDefinition Width="0.98*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CompactCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="{StaticResource App.GridLength.ContentGap}" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="現在の手順"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                                   Text="追加済みアクションの確認・削除を行います。"
                                   Style="{StaticResource BodyTextStyle}"
                                   Foreground="{DynamicResource App.Brush.TextSecondary}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="{StaticResource App.Thickness.TopGapM}"
                                   Text="シーケンス名"
                                   Style="{StaticResource LabelTextStyle}" />
                        <TextBox Margin="{StaticResource App.Thickness.TopGapS}"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding SequenceName, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                                   Text="{Binding StatusMessage}"
                                   Style="{StaticResource BodyTextStyle}"
                                   Foreground="{DynamicResource App.Brush.Warning}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Style="{StaticResource SubtlePanelStyle}">
                        <Grid>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="まだアクションがありません。右側のパレットから追加してください。"
                                       Foreground="{DynamicResource App.Brush.TextMuted}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentSteps.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ListBox ItemsSource="{Binding CurrentSteps}"
                                     ItemContainerStyle="{StaticResource FlatListBoxItemStyle}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.Style>
                                    <Style TargetType="ListBox">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentSteps.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="{StaticResource App.Thickness.ListItemPadding}"
                                                CornerRadius="{StaticResource App.CornerRadius.Control}"
                                                Background="{DynamicResource App.Brush.Surface}"
                                                BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                                                BorderThickness="1">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="削除"
                                                              Command="{Binding RemoveCommand}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <DockPanel LastChildFill="True">
                                                    <Image Width="24"
                                                           Height="24"
                                                           Margin="0,0,8,0"
                                                           Source="{Binding IconSource}"
                                                           DockPanel.Dock="Left">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               VerticalAlignment="Center"
                                                               Style="{StaticResource CardTitleTextStyle}" />
                                                </DockPanel>

                                                <Button Grid.Column="1"
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Top"
                                                        Command="{Binding RemoveCommand}"
                                                        Style="{StaticResource DangerActionButtonStyle}">
                                                    <TextBlock Text="削除" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CompactCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="{StaticResource App.GridLength.ContentGap}" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="クラフターアクション"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                                   Text="カテゴリからアクションを追加します。"
                                   Style="{StaticResource BodyTextStyle}"
                                   Foreground="{DynamicResource App.Brush.TextSecondary}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                                   Text="{Binding LoadErrorMessage}"
                                   Foreground="{DynamicResource App.Brush.Warning}"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LoadErrorMessage}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <Border Grid.Row="2"
                            Style="{StaticResource SubtlePanelStyle}">
                        <Grid>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="クラフターアクションを読み込んでいます。"
                                       Foreground="{DynamicResource App.Brush.TextMuted}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLoadingActions}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="False">
                                <ItemsControl ItemsSource="{Binding AvailableActions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,10">
                                                <TextBlock Text="{Binding CategoryName}"
                                                           Style="{StaticResource LabelTextStyle}" />
                                                <ItemsControl Margin="{StaticResource App.Thickness.TopGapS}"
                                                              ItemsSource="{Binding Actions}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Command="{Binding AddToSequenceCommand}"
                                                                    Style="{StaticResource ActionTileButtonStyle}"
                                                                    ToolTip="{Binding DisplayName}">
                                                                <StackPanel VerticalAlignment="Center">
                                                                    <Image Width="{StaticResource App.Size.ActionTileIcon}"
                                                                           Height="{StaticResource App.Size.ActionTileIcon}"
                                                                           HorizontalAlignment="Center"
                                                                           Source="{Binding IconSource}">
                                                                        <Image.Style>
                                                                            <Style TargetType="Image">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Image.Style>
                                                                    </Image>

                                                                    <TextBlock Margin="{StaticResource App.Thickness.TopGapS}"
                                                                               HorizontalAlignment="Center"
                                                                               MaxWidth="{StaticResource App.Size.ActionTileTextMaxWidth}"
                                                                               Text="{Binding DisplayName}"
                                                                               TextAlignment="Center"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               TextWrapping="NoWrap"
                                                                               Style="{StaticResource CaptionTextStyle}" />
                                                                </StackPanel>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Style="{StaticResource SubtlePanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="{StaticResource App.GridLength.ContentGap}" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           Text="保存するとシーケンス一覧に反映されます。変更を破棄する場合はキャンセルを選択してください。"
                           Style="{StaticResource BodyTextStyle}"
                           Foreground="{DynamicResource App.Brush.TextSecondary}"
                           TextWrapping="Wrap" />

                <Button Grid.Column="1"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SmallActionButtonStyle}">
                    <TextBlock Text="キャンセル" />
                </Button>

                <Button Grid.Column="3"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource ActionButtonStyle}">
                    <TextBlock Text="保存" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
