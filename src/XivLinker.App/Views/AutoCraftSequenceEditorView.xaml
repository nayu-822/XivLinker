<UserControl x:Class="XivLinker.App.Views.AutoCraftSequenceEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="クラフトシーケンス名とステップを編集できます。"
                               Style="{StaticResource BodyTextStyle}"
                               Foreground="{DynamicResource App.Brush.TextSecondary}" />
                </StackPanel>

                <Button Grid.Column="1"
                        VerticalAlignment="Top"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource ActionButtonStyle}">
                    <TextBlock Text="保存" />
                </Button>

                <Button Grid.Column="3"
                        VerticalAlignment="Top"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource ActionButtonStyle}">
                    <TextBlock Text="キャンセル" />
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="シーケンス名"
                               Style="{StaticResource LabelTextStyle}" />
                    <TextBox Margin="0,8,0,0"
                             Padding="12,10"
                             Text="{Binding SequenceName, UpdateSourceTrigger=PropertyChanged}"
                             Background="{DynamicResource App.Brush.SurfaceAlt}"
                             BorderBrush="{DynamicResource App.Brush.Border}"
                             BorderThickness="1"
                             Foreground="{DynamicResource App.Brush.TextPrimary}" />

                    <Grid Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ステップ"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <Button Grid.Column="1"
                                Command="{Binding AddStepCommand}"
                                Style="{StaticResource ActionButtonStyle}">
                            <TextBlock Text="ステップ追加" />
                        </Button>
                    </Grid>

                    <ItemsControl Margin="0,16,0,0"
                                  ItemsSource="{Binding Steps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,12"
                                        Padding="16"
                                        CornerRadius="{StaticResource App.CornerRadius.Control}"
                                        Background="{DynamicResource App.Brush.SurfaceAlt}"
                                        BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="アクション名"
                                                   Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="待機(ms)"
                                                   Style="{StaticResource LabelTextStyle}" />

                                        <TextBox Grid.Row="1"
                                                 Margin="0,8,0,0"
                                                 Padding="12,10"
                                                 Text="{Binding ActionName, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="{DynamicResource App.Brush.SurfaceStrong}"
                                                 BorderBrush="{DynamicResource App.Brush.Border}"
                                                 BorderThickness="1"
                                                 Foreground="{DynamicResource App.Brush.TextPrimary}" />

                                        <TextBox Grid.Row="1"
                                                 Grid.Column="2"
                                                 Margin="0,8,0,0"
                                                 Padding="12,10"
                                                 Text="{Binding WaitMilliseconds, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="{DynamicResource App.Brush.SurfaceStrong}"
                                                 BorderBrush="{DynamicResource App.Brush.Border}"
                                                 BorderThickness="1"
                                                 Foreground="{DynamicResource App.Brush.TextPrimary}" />

                                        <Button Grid.Row="1"
                                                Grid.Column="4"
                                                Margin="0,8,0,0"
                                                Command="{Binding DataContext.DeleteStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ActionButtonStyle}">
                                            <TextBlock Text="削除" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
