<UserControl x:Class="XivLinker.App.Views.AutoCraftSequenceEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CompactCardStyle}">
            <StackPanel>
                <DockPanel LastChildFill="False">
                    <TextBlock Text="{Binding WindowTitle}"
                               Style="{StaticResource SectionTitleTextStyle}"
                               DockPanel.Dock="Left" />
                    <Border Margin="12,0,0,0"
                            Padding="10,4"
                            HorizontalAlignment="Right"
                            Background="{DynamicResource App.Brush.SurfaceAlt}"
                            BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource App.CornerRadius.Pill}">
                        <TextBlock Text="{Binding Title}"
                                   Style="{StaticResource CaptionTextStyle}" />
                    </Border>
                </DockPanel>

                <TextBlock Margin="0,8,0,0"
                           Text="名前を付けてシーケンスを保存し、右側のクラフターアクションパレットから手順に追加できます。"
                           Style="{StaticResource BodyTextStyle}"
                           Foreground="{DynamicResource App.Brush.TextSecondary}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.08*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CompactCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="シーケンス"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="シーケンス名を入力し、左側で追加済みアクションの並びを確認できます。"
                                   Style="{StaticResource BodyTextStyle}"
                                   Foreground="{DynamicResource App.Brush.TextSecondary}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,16,0,0"
                                   Text="シーケンス名"
                                   Style="{StaticResource LabelTextStyle}" />
                        <TextBox Margin="0,8,0,0"
                                 Padding="12,10"
                                 Text="{Binding SequenceName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource App.Brush.SurfaceAlt}"
                                 BorderBrush="{DynamicResource App.Brush.Border}"
                                 BorderThickness="1"
                                 Foreground="{DynamicResource App.Brush.TextPrimary}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding StatusMessage}"
                                   Style="{StaticResource BodyTextStyle}"
                                   Foreground="{DynamicResource App.Brush.Warning}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="まだアクションがありません。右側のパレットから追加してください。"
                                   Foreground="{DynamicResource App.Brush.TextMuted}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentSteps.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ListBox ItemsSource="{Binding CurrentSteps}"
                                 AlternationCount="999"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentSteps.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="{StaticResource App.Thickness.ListItemCompactPadding}"
                                            CornerRadius="{StaticResource App.CornerRadius.Control}"
                                            Background="{DynamicResource App.Brush.SurfaceAlt}"
                                            BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                                            BorderThickness="1">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="削除"
                                                          Command="{Binding RemoveCommand}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <DockPanel LastChildFill="True">
                                                <Image Width="24"
                                                       Height="24"
                                                       Margin="0,0,8,0"
                                                       Source="{Binding IconSource}"
                                                       DockPanel.Dock="Left">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Style="{StaticResource CardTitleTextStyle}" />
                                            </DockPanel>

                                            <Button Grid.Column="1"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Top"
                                                    Command="{Binding RemoveCommand}"
                                                    Style="{StaticResource ActionButtonStyle}">
                                                <TextBlock Text="削除" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CompactCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="クラフターアクション"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="カテゴリごとに並んだパレットからアクションを追加できます。パレットは縦スクロールします。"
                                   Style="{StaticResource BodyTextStyle}"
                                   Foreground="{DynamicResource App.Brush.TextSecondary}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,12,0,0"
                                   Text="クラフターアクションを読み込んでいます。"
                                   Foreground="{DynamicResource App.Brush.TextSecondary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoadingActions}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding LoadErrorMessage}"
                                   Foreground="{DynamicResource App.Brush.Warning}"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LoadErrorMessage}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                        <ItemsControl ItemsSource="{Binding AvailableActions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,16">
                                        <TextBlock Text="{Binding CategoryName}"
                                                   Style="{StaticResource LabelTextStyle}" />
                                        <ItemsControl Margin="0,8,0,0"
                                                      ItemsSource="{Binding Actions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding AddToSequenceCommand}"
                                                            Style="{StaticResource ActionTileButtonStyle}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="8" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <Image Width="{StaticResource App.Size.IconM}"
                                                                   Height="{StaticResource App.Size.IconM}"
                                                                   VerticalAlignment="Center"
                                                                   Source="{Binding IconSource}">
                                                                <Image.Style>
                                                                    <Style TargetType="Image">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Image.Style>
                                                            </Image>

                                                            <TextBlock Grid.Column="2"
                                                                       VerticalAlignment="Center"
                                                                       Text="{Binding DisplayName}"
                                                                       TextAlignment="Left"
                                                                       TextWrapping="Wrap"
                                                                       Style="{StaticResource BodyTextStyle}" />
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Style="{StaticResource CompactCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           Text="保存するとシーケンス一覧に反映されます。キャンセル時の変更は保存されません。"
                           Style="{StaticResource BodyTextStyle}"
                           Foreground="{DynamicResource App.Brush.TextSecondary}"
                           TextWrapping="Wrap" />

                <Button Grid.Column="1"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource ActionButtonStyle}">
                    <TextBlock Text="キャンセル" />
                </Button>

                <Button Grid.Column="3"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource ActionButtonStyle}">
                    <TextBlock Text="保存" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
