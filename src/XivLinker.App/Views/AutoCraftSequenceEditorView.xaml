<UserControl x:Class="XivLinker.App.Views.AutoCraftSequenceEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="左のアクションパレットから追加し、右側で順序と待機時間を調整します。"
                               Style="{StaticResource BodyTextStyle}"
                               Foreground="{DynamicResource App.Brush.TextSecondary}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Button Grid.Column="1"
                        VerticalAlignment="Top"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource ActionButtonStyle}">
                    <TextBlock Text="保存" />
                </Button>

                <Button Grid.Column="3"
                        VerticalAlignment="Top"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource ActionButtonStyle}">
                    <TextBlock Text="キャンセル" />
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="アクションパレット"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="利用可能なクラフターアクションをクリックすると、シーケンス末尾に追加されます。"
                                   Style="{StaticResource BodyTextStyle}"
                                   Foreground="{DynamicResource App.Brush.TextSecondary}"
                                   TextWrapping="Wrap" />

                        <TextBlock Margin="0,16,0,0"
                                   Text="クラフターアクションを読み込んでいます。"
                                   Foreground="{DynamicResource App.Brush.TextSecondary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoadingActions}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock Margin="0,12,0,0"
                                   Text="{Binding LoadErrorMessage}"
                                   Foreground="{DynamicResource App.Brush.Warning}"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LoadErrorMessage}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl Margin="0,20,0,0"
                                      ItemsSource="{Binding AvailableActions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,18">
                                        <TextBlock Text="{Binding CategoryName}"
                                                   Style="{StaticResource LabelTextStyle}" />
                                        <ItemsControl Margin="0,10,0,0"
                                                      ItemsSource="{Binding Actions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Width="168"
                                                            Height="80"
                                                            Margin="0,0,12,12"
                                                            Command="{Binding AddToSequenceCommand}"
                                                            Style="{StaticResource ActionButtonStyle}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Padding="12"
                                                                        CornerRadius="{StaticResource App.CornerRadius.Control}"
                                                                        Background="{TemplateBinding Background}"
                                                                        BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                                                                        BorderThickness="1">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="28" />
                                                                            <ColumnDefinition Width="8" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <Image Width="24"
                                                                               Height="24"
                                                                               VerticalAlignment="Center"
                                                                               Source="{Binding IconSource}">
                                                                            <Image.Style>
                                                                                <Style TargetType="Image">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Image.Style>
                                                                        </Image>

                                                                        <TextBlock Grid.Column="2"
                                                                                   VerticalAlignment="Center"
                                                                                   Text="{Binding DisplayName}"
                                                                                   TextAlignment="Left"
                                                                                   TextWrapping="Wrap"
                                                                                   Style="{StaticResource BodyTextStyle}" />
                                                                    </Grid>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="シーケンス"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="アクション順は手動で整理できます。待機時間は必要に応じて調整してください。"
                                   Style="{StaticResource BodyTextStyle}"
                                   Foreground="{DynamicResource App.Brush.TextSecondary}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Margin="0,20,0,0">
                        <TextBlock Text="シーケンス名"
                                   Style="{StaticResource LabelTextStyle}" />
                        <TextBox Margin="0,8,0,0"
                                 Padding="12,10"
                                 Text="{Binding SequenceName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource App.Brush.SurfaceAlt}"
                                 BorderBrush="{DynamicResource App.Brush.Border}"
                                 BorderThickness="1"
                                 Foreground="{DynamicResource App.Brush.TextPrimary}" />

                        <TextBlock Margin="0,10,0,0"
                                   Text="{Binding StatusMessage}"
                                   Style="{StaticResource BodyTextStyle}"
                                   Foreground="{DynamicResource App.Brush.Warning}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid Grid.Row="2"
                          Margin="0,24,0,0">
                        <TextBlock Text="まだアクションがありません。左のパレットから追加してください。"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource App.Brush.TextMuted}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentSteps.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ListBox ItemsSource="{Binding CurrentSteps}"
                                 AlternationCount="999"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentSteps.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12"
                                            Padding="16"
                                            CornerRadius="{StaticResource App.CornerRadius.Control}"
                                            Background="{DynamicResource App.Brush.SurfaceAlt}"
                                            BorderBrush="{DynamicResource App.Brush.BorderSubtle}"
                                            BorderThickness="1">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="削除"
                                                          Command="{Binding RemoveCommand}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <DockPanel LastChildFill="True">
                                                    <Image Width="24"
                                                           Height="24"
                                                           Margin="0,0,10,0"
                                                           Source="{Binding IconSource}"
                                                           DockPanel.Dock="Left">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Style="{StaticResource CardTitleTextStyle}" />
                                                </DockPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Margin="16,0,0,0">
                                                <TextBlock Text="待機時間 (ms)"
                                                           Style="{StaticResource LabelTextStyle}" />
                                                <TextBox Margin="0,8,0,0"
                                                         Padding="12,10"
                                                         Text="{Binding WaitMilliseconds, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="{DynamicResource App.Brush.SurfaceStrong}"
                                                         BorderBrush="{DynamicResource App.Brush.Border}"
                                                         BorderThickness="1"
                                                         Foreground="{DynamicResource App.Brush.TextPrimary}" />
                                            </StackPanel>

                                            <Button Grid.Column="2"
                                                    Margin="16,0,0,0"
                                                    VerticalAlignment="Top"
                                                    Command="{Binding RemoveCommand}"
                                                    Style="{StaticResource ActionButtonStyle}">
                                                <TextBlock Text="削除" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
