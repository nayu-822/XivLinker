<UserControl x:Class="XivLinker.App.Views.PageHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid Margin="{StaticResource App.Thickness.PageHeaderMargin}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding Title, ElementName=Root}"
                       Style="{StaticResource SectionTitleTextStyle}" />
            <TextBlock Margin="{StaticResource App.Thickness.PageHeaderDescriptionMargin}"
                       Text="{Binding Description, ElementName=Root}"
                       Foreground="{DynamicResource App.Brush.TextSecondary}"
                       TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Description, ElementName=Root}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <ContentPresenter Grid.Column="1"
                          Margin="{StaticResource App.Thickness.PageHeaderActionSpacing}"
                          VerticalAlignment="Top"
                          Content="{Binding ActionContent, ElementName=Root}" />
    </Grid>
</UserControl>
