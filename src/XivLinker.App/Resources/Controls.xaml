<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="WindowBaseStyle" TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource App.Brush.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource App.Thickness.CardPadding}" />
        <Setter Property="CornerRadius" Value="{StaticResource App.CornerRadius.Card}" />
        <Setter Property="Background" Value="{DynamicResource App.Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="HeroPanelStyle"
           BasedOn="{StaticResource CardStyle}"
           TargetType="Border">
        <Setter Property="Padding" Value="28" />
        <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceStrong}" />
    </Style>

    <Style x:Key="StatusSummaryPanelStyle"
           BasedOn="{StaticResource CardStyle}"
           TargetType="Border">
        <Setter Property="Padding" Value="20" />
        <Setter Property="Margin" Value="24,0,0,0" />
        <Setter Property="Background" Value="#22182633" />
    </Style>

    <Style x:Key="StatusPillStyle" TargetType="Border">
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Background" Value="#22352621" />
        <Setter Property="CornerRadius" Value="{StaticResource App.CornerRadius.Pill}" />
        <Setter Property="BorderBrush" Value="#446D5B34" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="ActionButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}" />
        <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceStrong}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource App.CornerRadius.Control}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Brush.Accent}" />
                <Setter Property="Foreground" Value="#0F141D" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
