<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="WindowBaseStyle" TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource App.Brush.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource App.Thickness.CardPadding}" />
        <Setter Property="CornerRadius" Value="{StaticResource App.CornerRadius.Card}" />
        <Setter Property="Background" Value="{DynamicResource App.Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="CompactCardStyle"
           BasedOn="{StaticResource CardStyle}"
           TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource App.Thickness.CardPaddingCompact}" />
    </Style>

    <Style x:Key="DashboardStatusCardStyle"
           BasedOn="{StaticResource CompactCardStyle}"
           TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.BorderSubtle}" />
    </Style>

    <Style x:Key="SectionSurfaceStyle"
           TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource App.Thickness.SectionPadding}" />
        <Setter Property="CornerRadius" Value="{StaticResource App.CornerRadius.Card}" />
        <Setter Property="Background" Value="{DynamicResource App.Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.BorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="SubtlePanelStyle"
           TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource App.Thickness.SectionPaddingCompact}" />
        <Setter Property="CornerRadius" Value="{StaticResource App.CornerRadius.Control}" />
        <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.BorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="DenseSubtlePanelStyle"
           BasedOn="{StaticResource SubtlePanelStyle}"
           TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource App.Thickness.PanelPaddingDense}" />
    </Style>

    <Style x:Key="ReadOnlyValueContainerStyle"
           BasedOn="{StaticResource SubtlePanelStyle}"
           TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource App.Thickness.ControlPadding}" />
    </Style>

    <Style x:Key="LogRowStyle"
           TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource App.Thickness.ListItemDensePadding}" />
        <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.BorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource App.CornerRadius.Control}" />
    </Style>

    <Style x:Key="HeroPanelStyle"
           BasedOn="{StaticResource CardStyle}"
           TargetType="Border">
        <Setter Property="Padding" Value="28" />
        <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceStrong}" />
    </Style>

    <Style x:Key="StatusSummaryPanelStyle"
           BasedOn="{StaticResource CardStyle}"
           TargetType="Border">
        <Setter Property="Padding" Value="20" />
        <Setter Property="Margin" Value="24,0,0,0" />
        <Setter Property="Background" Value="#22182633" />
    </Style>

    <Style x:Key="StatusPillStyle" TargetType="Border">
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Background" Value="#22352621" />
        <Setter Property="CornerRadius" Value="{StaticResource App.CornerRadius.Pill}" />
        <Setter Property="BorderBrush" Value="#446D5B34" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="ActionButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}" />
        <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceStrong}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource App.CornerRadius.Control}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Brush.Accent}" />
                <Setter Property="Foreground" Value="{DynamicResource App.Brush.OnAccent}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SmallActionButtonStyle"
           BasedOn="{StaticResource ActionButtonStyle}"
           TargetType="Button">
        <Setter Property="Padding" Value="9,5" />
    </Style>

    <Style x:Key="DangerActionButtonStyle"
           BasedOn="{StaticResource SmallActionButtonStyle}"
           TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.BorderSubtle}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Brush.Error}" />
                <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Error}" />
                <Setter Property="Foreground" Value="{DynamicResource App.Brush.OnAccent}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Brush.Error}" />
                <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Error}" />
                <Setter Property="Foreground" Value="{DynamicResource App.Brush.OnAccent}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TinyActionButtonStyle"
           BasedOn="{StaticResource ActionButtonStyle}"
           TargetType="Button">
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style x:Key="TinyDangerActionButtonStyle"
           BasedOn="{StaticResource DangerActionButtonStyle}"
           TargetType="Button">
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
        <Setter Property="Padding" Value="{StaticResource App.Thickness.ControlPadding}" />
        <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}" />
        <Setter Property="CaretBrush" Value="{DynamicResource App.Brush.TextPrimary}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource App.Brush.Accent}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="InputBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource App.CornerRadius.Control}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.BorderSubtle}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="Padding" Value="{StaticResource App.Thickness.ControlPadding}" />
        <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}" />
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.BorderSubtle}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ComboBoxToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource App.CornerRadius.Control}">
                        <Grid Width="26"
                              HorizontalAlignment="Center">
                            <Path Width="10"
                                  Height="6"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Data="M 0 0 L 5 5 L 10 0"
                                  Stroke="{DynamicResource App.Brush.TextSecondary}"
                                  StrokeEndLineCap="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeThickness="1.8" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBorder"
                            Margin="4,2"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource App.CornerRadius.Control}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource App.Brush.ControlHover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource App.Brush.AccentSoft}" />
                            <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Padding" Value="{StaticResource App.Thickness.ControlPadding}" />
        <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="ComboBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource App.CornerRadius.Control}" />
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="28" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False" />
                            <ToggleButton Grid.Column="1"
                                          Background="Transparent"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Style="{StaticResource ComboBoxToggleButtonStyle}" />
                        </Grid>
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               PopupAnimation="Fade">
                            <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Margin="0,6,0,0"
                                    Background="{DynamicResource App.Brush.PopupBackground}"
                                    BorderBrush="{DynamicResource App.Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource App.CornerRadius.Control}">
                                <ScrollViewer CanContentScroll="True"
                                              SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="PART_Popup" Property="MinHeight" Value="32" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource App.Brush.ControlHover}" />
                            <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource App.Brush.BorderSubtle}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource App.Brush.SurfaceStrong}" />
                            <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource App.Brush.ControlDisabled}" />
                            <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextMuted}" />
                            <Setter Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InputComboBoxStyle"
           BasedOn="{StaticResource {x:Type ComboBox}}"
           TargetType="ComboBox">
        <Setter Property="MinWidth" Value="120" />
    </Style>

    <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="{DynamicResource App.Brush.ScrollThumb}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBorder"
                            Margin="2"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource App.Brush.ScrollThumbHover}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource App.Brush.ScrollThumbPressed}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarPageButtonStyle" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{DynamicResource App.Brush.ScrollTrack}" />
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6">
                        <Track x:Name="PART_Track"
                               IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                            </Track.Thumb>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarPageButtonStyle}" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Height" Value="12" />
                            <Setter Property="Width" Value="Auto" />
                        </Trigger>
                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter Property="Width" Value="12" />
                            <Setter Property="Height" Value="Auto" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ActionTileButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="{StaticResource App.Size.ActionTileWidth}" />
        <Setter Property="Height" Value="{StaticResource App.Size.ActionTileHeight}" />
        <Setter Property="Margin" Value="{StaticResource App.Thickness.ActionTileMargin}" />
        <Setter Property="Padding" Value="{StaticResource App.Thickness.ActionTilePadding}" />
        <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}" />
        <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.BorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="TileBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource App.CornerRadius.Control}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceStrong}" />
                <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Brush.Accent}" />
                <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}" />
                <Setter Property="Foreground" Value="{DynamicResource App.Brush.OnAccent}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="CompactActionTileButtonStyle"
           BasedOn="{StaticResource ActionTileButtonStyle}"
           TargetType="Button">
        <Setter Property="Width" Value="{StaticResource App.Size.ActionTileCompactWidth}" />
        <Setter Property="Height" Value="{StaticResource App.Size.ActionTileCompactHeight}" />
        <Setter Property="Margin" Value="{StaticResource App.Thickness.ActionTileCompactMargin}" />
        <Setter Property="Padding" Value="{StaticResource App.Thickness.ActionTileCompactPadding}" />
    </Style>

    <Style x:Key="FlatListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
