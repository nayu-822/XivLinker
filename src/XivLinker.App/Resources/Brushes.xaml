<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="App.Brush.Background" Color="#0F141D" />
    <SolidColorBrush x:Key="App.Brush.Surface" Color="#18202C" />
    <SolidColorBrush x:Key="App.Brush.SurfaceAlt" Color="#1F2936" />
    <SolidColorBrush x:Key="App.Brush.SurfaceStrong" Color="#243244" />
    <SolidColorBrush x:Key="App.Brush.Border" Color="#314254" />
    <SolidColorBrush x:Key="App.Brush.BorderSubtle" Color="#2A3747" />
    <SolidColorBrush x:Key="App.Brush.TextPrimary" Color="#F3F7FB" />
    <SolidColorBrush x:Key="App.Brush.TextSecondary" Color="#C5D0DD" />
    <SolidColorBrush x:Key="App.Brush.TextMuted" Color="#8D9BAA" />
    <SolidColorBrush x:Key="App.Brush.Accent" Color="#63D2C6" />
    <SolidColorBrush x:Key="App.Brush.Success" Color="#7AD7A5" />
    <SolidColorBrush x:Key="App.Brush.Warning" Color="#F4C56D" />
    <SolidColorBrush x:Key="App.Brush.Error" Color="#F0898E" />
</ResourceDictionary>
