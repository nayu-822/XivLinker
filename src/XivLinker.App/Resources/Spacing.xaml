<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:Double x:Key="App.Space.XS">4</sys:Double>
    <sys:Double x:Key="App.Space.S">8</sys:Double>
    <sys:Double x:Key="App.Space.M">12</sys:Double>
    <sys:Double x:Key="App.Space.L">16</sys:Double>
    <sys:Double x:Key="App.Space.XL">24</sys:Double>
    <sys:Double x:Key="App.Space.XXL">32</sys:Double>

    <CornerRadius x:Key="App.CornerRadius.Control">10</CornerRadius>
    <CornerRadius x:Key="App.CornerRadius.Card">18</CornerRadius>
    <CornerRadius x:Key="App.CornerRadius.Pill">999</CornerRadius>

