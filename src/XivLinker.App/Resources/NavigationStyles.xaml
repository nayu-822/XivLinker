<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="ShellHeaderCardStyle"
           BasedOn="{StaticResource CardStyle}"
           TargetType="Border">
        <Setter Property="Padding" Value="20,18" />
        <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceStrong}" />
    </Style>

    <Style x:Key="NavigationRailStyle"
           BasedOn="{StaticResource CardStyle}"
           TargetType="Border">
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="NavigationButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextSecondary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource App.CornerRadius.Control}">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#182B3B" />
                <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}" />
                <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.BorderSubtle}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="NavigationItemContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="{StaticResource App.CornerRadius.Control}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Background" Value="#1F3244" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
