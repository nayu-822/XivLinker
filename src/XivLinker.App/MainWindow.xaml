<Window x:Class="XivLinker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:XivLinker.App.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}"
        Title="XivLinker"
        Width="1280"
        Height="820"
        MinWidth="1040"
        MinHeight="720"
        Background="{DynamicResource App.Brush.Background}">
    <Grid Margin="{StaticResource App.Thickness.PageCompact}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="212" />
                <ColumnDefinition Width="{StaticResource App.GridLength.SectionGap}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource NavigationRailStyle}">
                <StackPanel>
                    <TextBlock Text="&#x30CA;&#x30D3;&#x30B2;&#x30FC;&#x30B7;&#x30E7;&#x30F3;"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <ItemsControl Margin="0,18,0,0"
                                  ItemsSource="{Binding NavigationItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource NavigationItemContainerStyle}">
                                    <Button Command="{Binding DataContext.SelectNavigationItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource NavigationButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}"
                                                       Style="{StaticResource ValueTextStyle}"
                                                       FontSize="14"
                                                       Width="22" />
                                            <TextBlock Text="{Binding Title}"
                                                       Style="{StaticResource BodyTextStyle}"
                                                       Margin="10,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <ContentControl Grid.Column="2"
                            Content="{Binding CurrentContentViewModel}" />
        </Grid>
    </Grid>
</Window>
